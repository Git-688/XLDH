 */
window.NavigationData = {
    // 统计信息 - 已更新为精确计算
    getStats: function() {
        let totalCategories = 0;
        let totalSubCategories = 0;
        let totalWebsites = 0;
        
        for (const category in this.categories) {
            totalCategories++;
            totalSubCategories += Object.keys(this.categories[category]).length;
            for (const subCategory in this.categories[category]) {
                totalWebsites += this.categories[category][subCategory].length;
            }
        }
        
        return {
            totalCategories,
            totalSubCategories,
            totalWebsites
        };
    },
    
    // 获取所有一级分类
    getCategoryList: function() {
        return Object.keys(this.categories);
    },
    
    // 获取一级分类详情
    getCategoryInfo: function(category) {
        return {
            name: category,
            subCategories: Object.keys(this.categories[category] || {}),
            description: this.descriptions?.[category] || '',
            icon: this.categoryIcons?.[category] || 'fas fa-folder'
        };
    },
    
    // 获取二级分类数据
    getLevel2Data: function(level2) {
        for (const category in this.categories) {
            for (const subCategory in this.categories[category]) {
                if (subCategory === level2) {
                    return this.categories[category][subCategory];
                }
            }
        }
        return [];
    },
    
    // 获取所有网站数据
    getAllWebsites: function() {
        const allWebsites = [];
        for (const category in this.categories) {
            for (const subCategory in this.categories[category]) {
                const websites = this.categories[category][subCategory];
                websites.forEach(website => {
                    website.category = category;
                    website.subCategory = subCategory;
                    allWebsites.push(website);
                });
            }
        }
        return allWebsites;
    },
    
